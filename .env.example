# ============================================================
# Microsoft 365 Agents SDK — local development settings
# ============================================================

# --- Phase 1–4: empty values are OK for local anonymous mode ---
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__ANONYMOUS_ALLOWED=True
CLIENTID=
CLIENTSECRET=
TENANTID=

# --- Phase 5: Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# --- Phase 6: Azure AI Search (RAG) ---
AZURE_SEARCH_ENDPOINT=https://YOUR-SEARCH.search.windows.net
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=helpdesk-docs

# --- Phase 8: Agent 365 enterprise (filled later) ---
A365_AGENT_ID=
A365_TENANT_ID=
A365_BLUEPRINT_ID=

# --- Phase 9: Azure deployment (filled later) ---
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_APP_INSIGHTS_CONNECTION_STRING=
